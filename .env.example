# =============================================================================
# SiteComply — environment variables
# Copy to ".env" for local development. In production these are supplied by
# Azure App Service application settings / Azure Key Vault references.
# NEVER commit a real ".env" file or hard-code any of these values in source.
# =============================================================================

# --- Application -------------------------------------------------------------
# Public base URL of the running app (used for SSO redirect URIs and links).
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (Azure Database for PostgreSQL Flexible Server) -----------------
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# For local dev you may point this at a local Postgres instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sitecomply?schema=public"

# --- Admin auth: Microsoft Azure AD (MSAL) -----------------------------------
# From your Azure AD App Registration (admin sign-in via Microsoft SSO).
AZURE_AD_TENANT_ID=""
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# Must match a Redirect URI registered on the app, e.g. {APP_BASE_URL}/api/auth/callback
AZURE_AD_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Secret used to sign admin/worker session cookies (generate a long random value).
SESSION_SECRET=""

# --- Worker auth: SMS one-time passcode --------------------------------------
# Which SMS provider to use behind the SmsProvider interface: "acs" | "twilio" | "mock"
# Use "mock" locally to log codes to the console instead of sending real texts.
SMS_PROVIDER="mock"

# Azure Communication Services (default provider)
ACS_CONNECTION_STRING=""
# The provisioned sender number in E.164 (e.g. +447700000000) or alphanumeric sender id.
ACS_SMS_SENDER=""

# Twilio (alternative provider — stub)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""

# One-time passcode behaviour
OTP_TTL_SECONDS="300"
OTP_LENGTH="6"
